# LNG Fleet Performance Management System
# Copy to .env and fill in values

# Database
DB_URL=postgres://lngfleet:lngfleet_dev@localhost:5432/lngfleet
DB_PASSWORD=lngfleet_dev

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT Authentication
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# Open-Meteo Weather API (free, no key required)
WEATHER_API_BASE=https://api.open-meteo.com/v1

# CMEMS (Copernicus Marine) — register at marine.copernicus.eu
CMEMS_USERNAME=
CMEMS_PASSWORD=

# Satellite Communication
SATELLITE_MQTT_ENDPOINT=
SATELLITE_MQTT_USERNAME=
SATELLITE_MQTT_PASSWORD=

# Edge Gateway (onboard defaults)
EDGE_VESSEL_ID=
EDGE_MODBUS_ENDPOINT=192.168.1.100:502
EDGE_OPCUA_ENDPOINT=opc.tcp://192.168.1.101:4840
EDGE_MQTT_BROKER=mqtt://localhost:1883

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000

# Prometheus
PROMETHEUS_PORT=9090

# Environment
ENV=development
LOG_LEVEL=info
